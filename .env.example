# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — Dashboard > Settings > API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Base URL of this app (used for OAuth redirects, webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to true to run the UI against lib/mock-data.ts instead of Supabase
NEXT_PUBLIC_UI_ONLY=true
